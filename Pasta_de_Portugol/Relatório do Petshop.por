programa {
  funcao inicio() 
  {
    cadeia nome,cpf,nascimento,sexo,civil,mae,pai,telefone,celular,email,rua,complemento,bairro,cidade,estado,pais,ponto,pet,especie,raca,marca,modelo,cor,placa,chassi,tipo,combustivel,cidader,cep,sexo_pet,nascimento_pet,veterinario,alimentacao
    inteiro rg,numero,anof,anom,renavam,quilometragem,portas,idade,microchip
    real peso
    //Dados do Cliente
    escreva ("Digite o seu nome completo= ")
    leia (nome)
    escreva ("Digite o seu CPF= ")
    leia (cpf)
    escreva ("Digite o seu RG= ")
    leia (rg)
    escreva ("Digite a sua data de nascimento= ")
    leia (nascimento)
    escreva ("Digite o seu sexo= ")
    leia (sexo)
    escreva ("Digite o seu telefone fixo= ")
    leia (telefone)
    escreva ("Digite o seu telefone celular= ")
    leia (celular)
    escreva ("Digite o seu email= ")
    leia (email)
    escreva ("Digite o seu estado civil= ")
    leia (civil)
    escreva ("Digite o nome da sua mãe= ")
    leia (mae)
    escreva ("Digite o nome do seu pai= ")
    leia (pai)
    //Endereço
    escreva ("Digite o nome da sua rua de residência= ")
    leia (rua)
    escreva ("Digite o número da sua residência= ")
    leia (numero)
    escreva ("Digite um complemento em relação a sua residência= ")
    leia (complemento)
    escreva ("Digite o nome do seu bairro de residência= ")
