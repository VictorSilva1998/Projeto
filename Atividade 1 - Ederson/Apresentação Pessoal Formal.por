programa {
  funcao inicio() 
  {
   cadeia nome
   cadeia curso
   cadeia instituicao
   cadeia periodo
   escreva ("Digite o seu nome completo= ")
   leia (nome)
   escreva ("Digite o nome do seu curso= ")
   leia (curso)
   escreva ("Digite o nome da instituição= ")
   leia (instituicao)
   escreva ("Digite o seu periodo do curso= ")
   leia (periodo)
   escreva ("Eu, ",nome,", estudante do curso de ",curso," na instituição ",instituicao,", estou atualmente no ",periodo," periodo.")
  }
}
