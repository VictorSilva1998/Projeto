programa {
  funcao inicio() 
  {
   cadeia nome
   inteiro idade
   cadeia cidade
   cadeia profissao
   escreva ("Digite o seu nome= ")
   leia (nome)
   escreva ("Digite a sua idade= ")
   leia (idade)
   escreva ("Digite a sua cidade= ")
   leia (cidade)
   escreva ("Digite a sua profissão= ")
   leia (profissao)
   escreva ("Olá, meu nome é ",nome,", tenho ",idade," anos, moro em ",cidade," e trabalho como ",profissao,".")
  }
}
