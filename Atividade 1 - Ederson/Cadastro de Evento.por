programa {
  funcao inicio() 
  {
   cadeia nome
   cadeia local
   cadeia data
   cadeia organizador
   escreva ("Digite o nome do Evento= ")
   leia (nome)
   escreva ("Digite o local do Evento= ")
   leia (local)
   escreva ("Digite a data do Evento= ")
   leia (data)
   escreva ("Digite o nome do organizador do Evento= ")
   leia (organizador)
   escreva ("O evento '",nome,"' acontecerá no local ",local," na data ",data," sob organização de ",organizador,".")
  }
}
