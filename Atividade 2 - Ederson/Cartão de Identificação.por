programa {
  funcao inicio() 
  {
    cadeia nome
    inteiro idade
    cadeia curso
    cadeia cidade
    escreva ("Digite o seu nome= ")
    leia (nome)
    escreva ("Digite a sua idade= ")
    leia (idade)
    escreva ("Digite qual é o seu curso= ")
    leia (curso)
    escreva ("Digite o nome da sua cidade= ")
    leia (cidade)
    escreva ("===CARTÃO DE IDENTIFICAÇÃO===\nNome: ",nome,"\nIdade: ",idade," anos\nCurso: ",curso,"\nCidade: ",cidade)
  }
}
