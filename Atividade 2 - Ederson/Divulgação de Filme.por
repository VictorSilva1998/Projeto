programa {
  funcao inicio() 
  {
    cadeia filme
    cadeia genero
    cadeia horario
    cadeia sala
    escreva ("Digite o nome do filme= ")
    leia (filme)
    escreva ("Digite qual o gênero do filme= ")
    leia (genero)
    escreva ("Digite o horário de exibição do filme= ")
    leia (horario)
    escreva ("Digite a sala na qual o filme será exibido= ")
    leia (sala)
    escreva ("Em cartaz: '",filme,"'\nGênero: ",genero,"\nHorário: ",horario,"\nSala: ",sala)
  }
}
