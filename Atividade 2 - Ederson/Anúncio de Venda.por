programa {
  funcao inicio() 
  {
    cadeia produto
    cadeia marca
    real preco
    cadeia vendedor
    escreva ("Digite o nome do produto= ")
    leia (produto)
    escreva ("Digite a marca do produto= ")
    leia (marca)
    escreva ("Digite o preço do produto= ")
    leia (preco)
    escreva ("Digite o nome do vendedor= ")
    leia (vendedor)
    escreva ("Vende-se ",produto," da marca ",marca,",\npelo valor de ",preco,".\nInteressado procurar por ",vendedor,".")
  }
}
