programa {
  funcao inicio() 
  {
    cadeia nome
    cadeia livro
    cadeia autor
    cadeia data
    escreva ("Digite o nome do leitor= ")
    leia (nome)
    escreva ("Digite o título do livro= ")
    leia (livro)
    escreva ("Digite o nome do autor= ")
    leia (autor)
    escreva ("Digite a data do empréstimo= ")
    leia (data)
    escreva ("Registro de Empréstimo\n\nO leitor ",nome," retirou o livro '",livro,"',\nde autoria de ",autor,", no dia ",data,".")
  }
}
