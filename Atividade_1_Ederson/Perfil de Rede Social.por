programa {
  funcao inicio() {
   cadeia usuario
   inteiro idade
   cadeia cidade
   cadeia hobby
   escreva ("Digite o nome do Usuário= ")
   leia (usuario)
   escreva ("Digite a idade do usuário= ")
   leia (idade)
   escreva ("Digite o nome da cidade do usuário= ")
   leia (cidade)
   escreva ("Digite o hobby do usuário= ")
   leia (hobby)
   escreva ("Perfil de usuário:\nNome: ",usuario,"\nIdade: ",idade,"\nCidade: ",cidade,"\nHobby Favorito: ",hobby)
  }
}
