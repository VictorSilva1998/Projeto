programa {
  funcao inicio() 
  {
   cadeia produto
   cadeia marca
   inteiro codigo
   real preco
   escreva ("Digite o nome do produto= ")
   leia (produto)
   escreva ("Digite a marca do produto= ")
   leia (marca)
   escreva ("Digite o código do produto= ")
   leia (codigo)
   escreva ("Digite o preço do produto= ")
   leia (preco)
   escreva ("Produto cadastrado com sucesso!\nO item ",produto,", da marca ",marca,", código ",codigo,", está disponivel pelo valor de R$ ",preco,".")
  }
}
