programa {
  funcao inicio() 
  {
   cadeia filme
   cadeia diretor
   inteiro ano
   cadeia genero
   escreva ("Digite o nome do filme= ")
   leia (filme)
   escreva ("Digite o nome do diretor do filme= ")
   leia (diretor)
   escreva ("Digite o ano que o filme foi publicado= ")
   leia (ano)
   escreva ("Digite o gênero= ")
   leia (genero)
   escreva ("Hoje vamos apresentar o filme ",filme,", dirigido por ",diretor,", lançado em ",ano,", do gênero ",genero,".")
  }
}
