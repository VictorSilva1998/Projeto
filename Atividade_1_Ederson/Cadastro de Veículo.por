programa {
  funcao inicio()
  {
   cadeia nome
   cadeia marca
   cadeia modelo
   cadeia placa
   escreva ("Digite o nome do proprietário= ")
   leia (nome)
   escreva ("Digite a marca do veículo= ")
   leia (marca)
   escreva ("Digite o modelo do veículo= ")
   leia (modelo)
   escreva ("Digite a placa do veículo= ")
   leia (placa)
   escreva ("O veículo ",marca," modelo ",modelo,", placa ",placa,", está registrado em nome de ",nome,".")  
  }
}
