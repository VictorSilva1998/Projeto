programa {
  funcao inicio() {
   cadeia aluno
   cadeia serie
   cadeia escola
   cadeia turno
   escreva ("Digite o nome do Aluno= ")
   leia (aluno)
   escreva ("Digite a série do aluno= ")
   leia (serie)
   escreva ("Digite o nome da escola do aluno= ")
   leia (escola)
   escreva ("Digite o turno do aluno= ")
   leia (turno)
   escreva ("O aluno ",aluno," está matriculado na ", serie," série da escola ",escola,", no turno da ",turno,".")
  }
}
