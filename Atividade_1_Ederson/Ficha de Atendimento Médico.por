programa {
  funcao inicio() 
  {
   cadeia paciente
   inteiro idade
   cadeia sintoma
   cadeia data
   escreva ("Digite o nome do Paciente= ")
   leia (paciente)
   escreva ("Digite a idade do Paciente= ")
   leia (idade)
   escreva ("Digite o Sintoma Principal do Paciente= ")
   leia (sintoma)
   escreva ("Digite a data da consulta do Paciente= ")
   leia (data)
   escreva ("Paciente: ",paciente,"\nIdade: ",idade,"\nSintoma relatado: ",sintoma,"\nConsulta realizada em: ",data)
  }
}