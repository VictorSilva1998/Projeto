programa {
  funcao inicio() 
  {
    cadeia nome
    cadeia evento
    cadeia data
    cadeia local
    escreva ("Digite o nome do participante= ")
    leia (nome)
    escreva ("Digite o nome do evento= ")
    leia (evento)
    escreva ("Digite a data do evento= ")
    leia (data)
    escreva ("Digite o local do evento= ")
    leia (local)
    escreva ("O participante ",nome," está inscrito no evento ",evento,",\nque acontecerá em ",local,", na data ",data,".")
  }
}
